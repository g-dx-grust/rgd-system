# ============================
# RGDシステム 環境変数テンプレート
# ============================
# このファイルをコピーして値を設定すること:
#   ローカル開発: cp .env.example .env.local
#   ステージング: Vercel ダッシュボード > Settings > Environment Variables (Preview)
#   本番:         Vercel ダッシュボード > Settings > Environment Variables (Production)
#
# 本ファイルはバージョン管理対象（機密情報を記載しない）
# .env.local / .env.production.local は必ず .gitignore に含めること
# ============================

# -------------------------------------------------------
# 環境識別
# -------------------------------------------------------
# "development" | "staging" | "production"
APP_ENV=development

# アプリバージョン（Vercel では VERCEL_GIT_COMMIT_SHA を使うこともできる）
NEXT_PUBLIC_APP_VERSION=0.1.0

# -------------------------------------------------------
# Supabase
# -------------------------------------------------------
# Supabase ダッシュボード > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# サービスロールキー — サーバーサイド専用 / クライアントバンドルに含めない
# Supabase ダッシュボード > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT シークレット（RLS の署名検証に使用、必要な場合のみ設定）
# SUPABASE_JWT_SECRET=your-jwt-secret-here

# -------------------------------------------------------
# アプリケーション URL
# -------------------------------------------------------
# Vercel 本番デプロイ後は VERCEL_URL が自動設定されるが、
# 内部リンク生成には明示的に指定する
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 顧客向けポータルのベースURL（内部画面とサブドメインを分ける場合）
# NEXT_PUBLIC_PORTAL_URL=https://portal.example.com

# -------------------------------------------------------
# タイムゾーン
# -------------------------------------------------------
TZ=Asia/Tokyo

# -------------------------------------------------------
# メール送信（選定後に設定）
# -------------------------------------------------------
# Resend を使用する場合:
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@example.com

# SendGrid を使用する場合:
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@example.com

# -------------------------------------------------------
# Lark 連携（補助的な通知のみ利用する場合）
# -------------------------------------------------------
# LARK_APP_ID=cli_xxxxxxxxxxxx
# LARK_APP_SECRET=your-lark-app-secret
# LARK_WEBHOOK_SECRET=your-webhook-secret

# -------------------------------------------------------
# ストレージ設定
# -------------------------------------------------------
# Supabase Storage バケット名（デプロイ環境ごとに別バケットを推奨）
# デフォルト値はコード内定数で定義している
# STORAGE_BUCKET_DOCUMENTS=rgd-documents
# STORAGE_BUCKET_PACKAGES=rgd-packages

# ファイルサイズ上限 (MB) — デフォルト 100
# NEXT_PUBLIC_MAX_FILE_SIZE_MB=100

# -------------------------------------------------------
# 移行・インポートツール用（本番運用後は不要）
# -------------------------------------------------------
# CSV インポート実行時のみ設定する
# IMPORT_DRY_RUN=true
# IMPORT_BATCH_SIZE=50
